{
  "name": "markeplace",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:ts && npm run build:css",
    "build:ts": "tsc",
    "build:css": "tailwindcss -i ./src/frontend/style.css -o ./dist/style.css --minify",
    "watch:css": "tailwindcss -i ./src/frontend/style.css -o ./dist/style.css --watch"
  },
  "dependencies": {
    "@headlessui/tailwindcss": "^0.2.2",
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
